<!DOCTYPE html>
<html lang="en">
  <!-- Head -->
  <%- include('../../partials/head.ejs') %>
  <body>
    <!-- Header -->
    <%- include('../../partials/header.ejs') %>

    <!-- Sidebar -->
    <%- include('../../partials/sidebar.ejs') %>

    <!-- Main content -->
    <main class="main">
      <!-- Genres subheader -->
      <%- include('./genres-header.ejs') %>

      <div class="editor">
        <h3 class="sub-title"><%= locals.isUpdate ? 'Update Genre' : 'Add Genre' %></h3>

        <!-- Show validation errors -->
        <%  if(locals.errors) {%>
          <%- include("../../partials/errors.ejs") %>
        <% } %> 

        <!-- Dialog modal -->
        <!-- closedby attribute is not supported in Safari -->
        <dialog class="modal" closedby="any">
          <p class="modal__text">Enter Admin password to update</p>
            <div class="form__control">
              <label class="form__label form__label--modal" for="admin-pw">Admin password</label>
              <!-- Connect input and Confirm button to form with form attribute-->
              <input form="genre-form" class="form__input form__input--modal" type="password" name="password" id="admin-pw" required>
            </div>
            <div class="btn-group">
              <button class="btn btn--primary btn--cancel" type="button" onclick="closeModal()">Cancel</button>
              <button form="genre-form" class="btn btn--primary btn--confirm" type="submit">Confirm</button>
            </div>
        </dialog>

        <!-- Genre form -->
        <form id="genre-form" action="<%= locals.isUpdate ? '/genres/' + genreId + '/update' : '/genres/new' %>"
          method="post"     class="form">
          <div class="form__control">
            <label class="form__label" for="type"> Type </label>
            <input class="form__input" type="text" name="type" id="type"
            value="<%= locals.genre?.type || '' %>" required  />
          </div>

          <div class="btn-group btn-group--form">
            <!-- Cancel link -->
            <a href="/genres" class="link link--cancel">Cancel</a>

            <!-- Add or Update button -->
            <button class="btn btn--primary btn--add"
            onclick="openModal(event)"><%= locals.isUpdate ? 'Update' : 'Add' %></button>
          </div>
        </form>
      </div>
    </main>

    <!-- Footer -->
    <%- include('../../partials/footer.ejs') %>

    <script>
      const modal = document.querySelector('.modal')

      /* Open update modal */
      function openModal(event) {
        event.preventDefault()
        modal.showModal()
      }

      /* Close update modal */
      function closeModal() {
        modal.close()
      }
    </script>
  </body>
</html>
